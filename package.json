{
  "name": "kitchen-store-requisition",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:infra\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:infra": "docker compose -f docker-compose.dev.yml up postgres redis",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:reset": "docker compose -f docker-compose.dev.yml down -v",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build",
    "dev:backend": "npm --workspace apps/backend run start:dev",
    "dev:frontend": "npm --workspace apps/frontend run dev",
    "build:backend": "npm --workspace apps/backend run build",
    "lint:backend": "npm --workspace apps/backend run lint",
    "improve": "tsx scripts/code-improver.ts"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "concurrently": "^8.2.2",
    "tsx": "^4.21.0"
  }
}
