    { "fieldname": "created_by", "fieldtype": "Link", "options": "User" },
    { "fieldname": "submitted_at", "fieldtype": "Datetime" },
    { "fieldname": "issued_at", "fieldtype": "Datetime" },
    { "fieldname": "completed_at", "fieldtype": "Datetime" },
    { "fieldname": "stock_entry", "fieldtype": "Link", "options": "Stock Entry" },
    { "fieldname": "queue_job_id", "fieldtype": "Data" },
    { "fieldname": "notes", "fieldtype": "Text" },
    { "fieldname": "items", "fieldtype": "Table", "options": "Kitchen Requisition Item" }
